# ── IREM static site .gitignore ──────────────────────────────

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Scratch / temp
tmp/

# Source images (raw AI generations, original photos, archived candidates).
# These are NOT part of the site — only the optimized .webp under
# public/media/images/pages/ and shared/ are referenced and shipped.
# Kept out of git so they can never be accidentally committed or published.
public/media/images/ai-generated/
public/media/images/real-photos/
public/media/images/archive/

# Secrets — never commit
.env
.env.*
*.pem
*.keystore
firebase-key.json
google-services.json

# Node (only relevant if tooling is added later)
node_modules/
npm-debug.log*
